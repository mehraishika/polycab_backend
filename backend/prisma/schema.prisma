  dc_voltage_9              Decimal? @db.Decimal(12, 3)

  dc_current_1              Decimal? @db.Decimal(12, 3)
  dc_current_2              Decimal? @db.Decimal(12, 3)
  dc_current_3              Decimal? @db.Decimal(12, 3)
  dc_current_4              Decimal? @db.Decimal(12, 3)
  dc_current_5              Decimal? @db.Decimal(12, 3)
  dc_current_6              Decimal? @db.Decimal(12, 3)
  dc_current_7              Decimal? @db.Decimal(12, 3)
  dc_current_8              Decimal? @db.Decimal(12, 3)
