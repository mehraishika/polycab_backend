generator client {
  provider = "prisma-client"
  output   = "../src/server/db/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                BigInt                 @id @default(autoincrement())
  account           String                 @unique
  email             String?
  passwordHash      String                 @map("password_hash")
  portal            UserPortal
  role              UserRole
  status            UserStatus             @default(active)
  assignedById      BigInt?
  timezone          String?
  phone             String?
  address           String?
  emailVerifiedAt   DateTime?              @map("email_verified_at")
  lastLoginAt       DateTime?              @map("last_login_at")
  createdAt         DateTime               @default(now()) @map("created_at")
  updatedAt         DateTime               @updatedAt @map("updated_at")
  isDeleted         Boolean                @default(false)
  deletedAt         DateTime?
  plants            Plant[]
  plantInverterMaps UserPlantInverterMap[]
  assignedBy        User?                  @relation("UserAssignment", fields: [assignedById], references: [id])
  assignedUsers     User[]                 @relation("UserAssignment")

  @@unique([portal, email])
  @@index([portal, role])
  @@index([status])
  @@index([assignedById])
  @@map("users")
}

model Plant {
  id               BigInt                 @id @default(autoincrement())
  name             String
  type             String
  installed        DateTime?
  lastUpdatedAt    DateTime?              @map("last_updated_at")
  kwp              Float?
  price            Float?
  priceUnit        String?                @map("price_unit")
  longitude        String?
  latitude         String?
  address          String?
  pictureFileId    String?                @map("picture_file_id")
  userAccount      String                 @map("user_account")
  createdAt        DateTime               @default(now()) @map("created_at")
  updatedAt        DateTime               @updatedAt @map("updated_at")
  deletedAt        DateTime?              @map("deleted_at")
  dataloggers      DeviceDatalogger[]
  inverters        DeviceInverter[]
  information_data information_data[]
  user             User                   @relation(fields: [userAccount], references: [account])
  currentStatus    PlantCurrentStatus?
  alertStates      DeviceAlertState[]
  alertEvents      AlertEvent[]

  @@index([type])
  @@index([name])
  @@index([userAccount])
  @@index([deletedAt])
  @@map("plants")
}

model DeviceInverter {
  id            BigInt                @id @default(autoincrement())
  name          String?
  type          String                @default("inverter")
  serialNumber  String                @unique @map("serial_number")
  updateTime    DateTime?             @map("update_time")
  plantId       BigInt                @map("plant_id")
  createdAt     DateTime              @default(now()) @map("created_at")
  updatedAt     DateTime              @updatedAt @map("updated_at")
  deletedAt     DateTime?             @map("deleted_at")
  dataloggers   DeviceDatalogger[]
  plant         Plant                 @relation(fields: [plantId], references: [id])
  remoteSettings     DeviceRemoteSetting[]
  remoteSettingTasks DeviceRemoteSettingTask[]

  @@index([plantId])
  @@index([serialNumber])
  @@index([type])
  @@index([deletedAt])
  @@map("device_inverters")
}

model DeviceRemoteSetting {
  id               BigInt            @id @default(autoincrement())
  deviceInverterId BigInt            @map("device_inverter_id")
  tab              RemoteSettingsTab
  settings         Json
  updatedById      BigInt?           @map("updated_by_id")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  deviceInverter    DeviceInverter   @relation(fields: [deviceInverterId], references: [id])

  @@unique([deviceInverterId, tab])
  @@index([deviceInverterId])
  @@map("device_remote_settings")
}

model DeviceRemoteSettingTask {
  id               BigInt                   @id @default(autoincrement())
  deviceInverterId BigInt                   @map("device_inverter_id")
  kind             RemoteSettingsTaskKind
  tab              RemoteSettingsTab?
  payload          Json
  status           RemoteSettingsTaskStatus @default(pending)
  createdById      BigInt?                  @map("created_by_id")
  createdAt        DateTime                 @default(now()) @map("created_at")
  updatedAt        DateTime                 @updatedAt @map("updated_at")
  deviceInverter    DeviceInverter          @relation(fields: [deviceInverterId], references: [id])

  @@index([deviceInverterId])
  @@index([status])
  @@map("device_remote_setting_tasks")
}

// Reference/catalog table — which register on the physical inverter each
// remote-setting field maps to. Populated externally (register-mapping
// exercise), read-only from the application's perspective.
model RemoteSettingParameterMaster {
  id              BigInt   @id @default(autoincrement())
  tab             String   @db.VarChar(40)
  tabLabel        String   @map("tab_label") @db.VarChar(60)
  fieldKey        String   @map("field_key") @db.VarChar(60)
  label           String   @db.VarChar(150)
  dataType        String   @map("data_type") @db.VarChar(20)
  unitOrOptions   String?  @map("unit_or_options") @db.VarChar(200)
  endpointPath    String   @map("endpoint_path") @db.VarChar(120)
  displayOrder    Int      @map("display_order")
  count           Int      @default(1)
  registerAddress String?  @map("register_address") @db.VarChar(20)
  registerType    String?  @map("register_type") @db.VarChar(20)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @map("updated_at") @db.Timestamptz(6)

  @@unique([tab, fieldKey])
  @@index([tab])
  @@map("remote_setting_parameter_master")
}

// Register-mapping catalog for the /remote-settings/command endpoint's four
// actions (afdReset, syncDateTime, reset, clearAllData). Kept separate from
// RemoteSettingParameterMaster because commands aren't tab-scoped settings —
// no `tab` column here, just one row per command key. Populated externally,
// read-only from the application's perspective.
model RemoteSettingCommandMaster {
  id              BigInt   @id @default(autoincrement())
  commandKey      String   @unique @map("command_key") @db.VarChar(60)
  label           String   @db.VarChar(150)
  endpointPath    String   @default("/remote-settings/command") @map("endpoint_path") @db.VarChar(120)
  displayOrder    Int      @map("display_order")
  count           Int      @default(1)
  registerAddress String?  @map("register_address") @db.VarChar(20)
  registerType    String?  @default("coil") @map("register_type") @db.VarChar(20)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("remote_setting_command_master")
}

enum RemoteSettingsTab {
  gridParameters
  featureParameters
  reactivePowerControl
  powerLimit
  otherSetting
  maskingFaultDetection
}

enum RemoteSettingsTaskKind {
  settings
  command
}

enum RemoteSettingsTaskStatus {
  pending
  completed
  failed
}

model UserPlantInverterMap {
  id                 BigInt                           @id @default(autoincrement())
  userId             BigInt                           @map("user_id")
  plantId            BigInt?                          @map("plant_id")
  serialNumber       String                           @unique @map("inverter_no")
  isDeleted          Boolean                          @default(false) @map("is_deleted")
  deletedAt          DateTime?                        @map("deleted_at")
  createdAt          DateTime                         @default(now()) @map("created_at")
  updatedAt          DateTime                         @updatedAt @map("updated_at")
  dailySummaries     DeviceDailySummary[]
  lineChartSummaries DeviceDailySummaryPerLineChart[]
  invertorStatus     DeviceInvertorStatus?            @relation("MapToInvertorStatus")
  user               User                             @relation(fields: [userId], references: [id])

  @@index([userId, isDeleted])
  @@index([plantId, isDeleted])
  @@index([serialNumber])
  @@index([serialNumber, isDeleted])
  @@index([deletedAt])
  @@map("user_plant_inverter_map")
}

model DeviceInvertorStatus {
  id                   BigInt               @id @default(autoincrement())
  deviceSno            String               @unique @map("device_sno")
  latestTimeState      DateTime             @map("latest_time_state")
  status               Boolean              @default(false)
  createdAt            DateTime             @default(now()) @map("created_at")
  updatedAt            DateTime             @updatedAt @map("updated_at")
  userPlantInverterMap UserPlantInverterMap @relation("MapToInvertorStatus", fields: [deviceSno], references: [serialNumber], map: "device_invertor_status_device_sno_user_plant_inverter_map_fkey")

  @@index([status])
  @@index([latestTimeState])
  @@index([deviceSno, status])
  @@map("device_invertor_status")
}

model DeviceDatalogger {
  id           BigInt          @id @default(autoincrement())
  name         String?
  type         String          @default("datalogger")
  serialNumber String          @unique @map("serial_number")
  online       Boolean         @default(false)
  status       String?
  updateTime   DateTime?       @map("update_time")
  plantId      BigInt          @map("plant_id")
  inverterId   BigInt?         @map("inverter_id")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")
  deletedAt    DateTime?       @map("deleted_at")
  inverter     DeviceInverter? @relation(fields: [inverterId], references: [id])
  plant        Plant           @relation(fields: [plantId], references: [id])

  @@index([plantId])
  @@index([inverterId])
  @@index([serialNumber])
  @@index([online])
  @@index([deletedAt])
  @@map("device_dataloggers")
}

