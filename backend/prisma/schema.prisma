model information_data {
  id               BigInt   @id @default(autoincrement())
  input_power      Float?   @map("Input Power")
  co2              Float?
  tree_planting    Float?   @map("Tree Planting")
  efficiency       Float?
  weather          String?
  irradiance       Float?
  cell_temperature Float?
  plantid          BigInt
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt
  plant            Plant    @relation(fields: [plantid], references: [id])

  @@index([plantid])
  @@map("information_data")
}

model DeviceConnectionStatus {
  id           BigInt    @id @default(autoincrement())
  serialNumber String    @unique @map("serial_number") @db.VarChar(255)
  macAddress   String?   @map("mac_address") @db.VarChar(255)
  status       String    @db.VarChar(50)
  lastSeenTime DateTime? @map("lastSeenTime") @db.Timestamptz(6)

  @@index([status], map: "idx_device_connection_status_status")
  @@map("device_connection_status")
}

model fota {
  id          Int     @unique @default(autoincrement())
  mac_address String  @id @db.VarChar(50)
  firmware    String? @db.VarChar(50)
  link        String? @db.VarChar(255)

  @@map("fota")
}

model DeviceCurrentStatus {
  id                BigInt      @id @default(autoincrement())
  sno               String      @unique
  status            PlantStatus @default(Offline)
  lastTelemetryAt   DateTime?   @map("last_telemetry_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  @@index([status])
  @@index([lastTelemetryAt])

  @@map("device_current_status")
}

model DeviceStatusHistory {
  id         BigInt      @id @default(autoincrement())
  sno        String
  plantId    BigInt?     @map("plant_id")
  status     PlantStatus
  createdAt  DateTime    @default(now()) @map("created_at")

  @@index([sno])
  @@index([plantId])
  @@index([status])

  @@map("device_status_history")
}

model PlantCurrentStatus {
  id              BigInt      @id @default(autoincrement())
  plantId         BigInt      @unique @map("plant_id")

  status          PlantStatus @default(Offline)

  totalDevices    Int         @default(0) @map("total_devices")
  normalCount     Int         @default(0) @map("normal_count")
  abnormalCount   Int         @default(0) @map("abnormal_count")
  standbyCount    Int         @default(0) @map("standby_count")
  offlineCount    Int         @default(0) @map("offline_count")

  updatedAt       DateTime    @updatedAt @map("updated_at")

  plant           Plant       @relation(fields: [plantId], references: [id])

  @@index([status])
  @@map("plant_current_status")
}

model DeviceAlertState {

  id                BigInt      @id @default(autoincrement())
  serialNumber      String      @unique @map("serial_number")
  plantId           BigInt?     @map("plant_id")
  plant             Plant?      @relation(fields: [plantId], references: [id])
  alertMatrix       Json        @map("alert_matrix")
  activeAlertCount  Int         @default(0) @map("active_alert_count")
  lastTelemetryAt   DateTime    @map("last_telemetry_at")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")
  @@index([serialNumber])
  @@index([plantId])
  @@map("device_alert_state")
}

model AlertEvent {

  id               BigInt       @id @default(autoincrement())
  serialNumber     String       @map("serial_number")
  plantId          BigInt?      @map("plant_id")
  plant            Plant?       @relation(fields: [plantId], references: [id])
  registerNo       Int          @map("register_no")
  bitPosition      Int          @map("bit_position")
  faultCode        String       @map("fault_code")
  faultMessage     String       @map("fault_message")
  status           AlertStatus
  raisedAt         DateTime?     @map("raised_at")
  clearedAt        DateTime?    @map("cleared_at")
  createdAt        DateTime     @default(now()) @map("created_at")
  @@index([serialNumber])
  @@index([plantId])
  @@index([status])
  @@map("alert_events")
}

model FaultDictionary {

  id             BigInt   @id @default(autoincrement())
  registerName   String   @map("register_name")      // ErrorCode1
  registerAddr   String   @map("register_addr")      // 0x101E
  registerNo     Int      @map("register_no")        // 1..6 (your matrix index)
  bitPosition    Int      @map("bit_position")
  faultCode      String   @map("fault_code")
  faultMessage   String   @map("fault_message")
  createdAt      DateTime @default(now()) @map("created_at")

  @@unique([registerNo, bitPosition])
  @@map("fault_dictionary")
}

