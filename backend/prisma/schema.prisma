  dc_voltage_4              Decimal? @db.Decimal(12, 3)
  dc_voltage_5              Decimal? @db.Decimal(12, 3)
  dc_voltage_6              Decimal? @db.Decimal(12, 3)
  dc_voltage_7              Decimal? @db.Decimal(12, 3)
