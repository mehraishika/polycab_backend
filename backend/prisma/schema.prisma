  dc_power_1                Decimal? @db.Decimal(12, 3)
  dc_power_2                Decimal? @db.Decimal(12, 3)
  dc_power_3                Decimal? @db.Decimal(12, 3)
  dc_power_4                Decimal? @db.Decimal(12, 3)
  dc_power_5                Decimal? @db.Decimal(12, 3)
  dc_power_6                Decimal? @db.Decimal(12, 3)
  dc_power_7                Decimal? @db.Decimal(12, 3)
  dc_power_8                Decimal? @db.Decimal(12, 3)
  dc_power_9                Decimal? @db.Decimal(12, 3)

  total_input_power         Decimal? @db.Decimal(14, 3)
  grid_total_active_power   Decimal? @db.Decimal(14, 3)
  grid_total_reactive_power Decimal? @db.Decimal(14, 3)

